{
  "name": "stokvel-management",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:backend": "jest backend/tests --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/backend/tests/**/*.test.js"
      
    ],
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/tests/**",
      "!**/node_modules/**"
    ],
    "clearMocks": true,
    "resetModules": true,
    "verbose": true,
    "moduleNameMapper": {
      "^@prisma/client$": "<rootDir>/node_modules/@prisma/client"
    }
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-oauth2-jwt-bearer": "^1.6.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.0.0"
  }
}