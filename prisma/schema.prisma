generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(dbgenerated("newid()"))
  providerId String   @unique
  email      String   @unique
  name       String
  createdAt  DateTime @default(now())
}