generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model contributions {
  contributionsId Int      @id(map: "PK_contributions") @default(autoincrement())
  FKgroupId       Int
  FKuserId        Int
  treasurerId     Int
  amount          Decimal  @db.Decimal(10, 2)
  dueDate         DateTime @db.Date
  paidAt          DateTime @db.DateTime
  status          String   @db.VarChar(15)
  note            String?  @db.VarChar(50)
  groups          groups   @relation(fields: [FKgroupId], references: [groupId], onUpdate: NoAction, map: "FKgroupId")
  users           users    @relation(fields: [FKuserId], references: [userId], onUpdate: NoAction, map: "FKuserId")
}

model group_audit_log {
  group_audit_logId Int      @id(map: "PK_group_audit_log") @default(autoincrement())
  TFKgroupId        Int
  field             String   @db.VarChar(15)
  oldValue          String?  @db.Text
  newValue          String?  @db.Text
  changedAt         DateTime @db.Date
  changedBy         Int
  users             users    @relation(fields: [changedBy], references: [userId], onUpdate: NoAction, map: "changedBy")
  groups            groups   @relation(fields: [TFKgroupId], references: [groupId], onUpdate: NoAction, map: "TFKgroupId")
}

model group_invites {
  group_inviteId Int      @id(map: "PK_group_invites") @default(autoincrement())
  SFKgroupId     Int
  token          String   @db.VarChar(150)
  email          String?  @db.VarChar(150)
  createdBy      Int
  createdAt      DateTime @db.Date
  expiresAt      DateTime @db.Date
  status         String   @db.VarChar(10)
  users          users    @relation(fields: [createdBy], references: [userId], onUpdate: NoAction, map: "createdBy")
  groups         groups   @relation(fields: [SFKgroupId], references: [groupId], onUpdate: NoAction, map: "SFKgroupId")
}

model group_members {
  group_memberId Int      @id(map: "PK_group_members") @default(autoincrement())
  FgroupId       Int
  SuserId        Int
  role           String   @db.VarChar(10)
  joinedAt       DateTime @db.Date
  groups         groups   @relation(fields: [FgroupId], references: [groupId], onUpdate: NoAction, map: "FgroupId")
  users          users    @relation(fields: [SuserId], references: [userId], onUpdate: NoAction, map: "SuserId")

  
}

model groups {
  groupId            Int               @id(map: "PK_groups") @default(autoincrement())
  name               String            @db.VarChar(50)
  description        String?           @db.Text
  contributionAmount Decimal           @db.Decimal(10, 2)
  cycleType          String            @db.VarChar(15)
  payoutOrder        String            @db.VarChar(50)
  startDate          DateTime          @db.Date
  status             String            @db.VarChar(15)
  createdBy          Int
  FiuserId           Int
  contributions      contributions[]
  group_audit_log    group_audit_log[]
  group_invites      group_invites[]
  group_members      group_members[]
  users              users             @relation(fields: [FiuserId], references: [userId], onUpdate: NoAction, map: "FiuserId")
  payouts            Payout[]
}

model users {
  userId          Int               @id(map: "Id") @default(autoincrement())
  providerId      String            @unique(map: "User_providerId_key")
  email           String            @unique(map: "User_email_key")
  name            String
  createdAt       DateTime          @default(now(), map: "User_createdAt_df") @db.Date
  contributions      contributions[]
  group_audit_log group_audit_log[]
  group_invites   group_invites[]
  group_members   group_members[]
  groups          groups[]
  payoutsReceived Payout[]          @relation("recipientPayouts")
  payoutsInitiated Payout[]         @relation("initiatorPayouts") 
}

model Payout {
  payoutId       Int      @id @default(autoincrement())
  groupId        Int      @map("FKgroupId")
  amount         Float
  recipientId    Int      @map("FKrecipientId")
  recipientName  String
  status         String   @default("pending")
  initiatedBy    Int      @map("FKinitiatedBy")
  initiatedAt    DateTime @default(now())
  processedAt    DateTime?
  transactionRef String?
  cycleNumber    Int
  notes          String?
  
  group          groups   @relation(fields: [groupId], references: [groupId], onDelete: NoAction, onUpdate: NoAction)
  recipient      users    @relation("recipientPayouts", fields: [recipientId], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  initiator      users    @relation("initiatorPayouts", fields: [initiatedBy], references: [userId], onDelete: NoAction, onUpdate: NoAction)
  
  @@map("payouts")
}